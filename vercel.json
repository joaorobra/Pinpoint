{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist-combined",
  "installCommand": "npm install && npm install --prefix website",
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
